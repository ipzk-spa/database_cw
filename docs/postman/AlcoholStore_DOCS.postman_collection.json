{
  "info": {
    "name": "Alcohol Store — DOCS (2 endpoints)",
    "description": "Практична робота DOCS: POST /auth/login та GET /alcohol/filter.\nПроєкт: https://github.com/ipzk-spa/database_cw",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    }
  ],
  "item": [
    {
      "name": "1. POST /auth/login — Авторизація",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        },
        "description": "Вхід користувача. Повертає JWT accessToken, email, userId.\nБізнес-вимога: BR-08. Без токена неможливе оформлення замовлення."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const json = pm.response.json();",
              "  if (json.accessToken) {",
              "    pm.collectionVariables.set('token', json.accessToken);",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. GET /alcohol/filter — Каталог з фільтрами",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/alcohol/filter?type_alcohol=Vodka&countries=Ukraine&volume=0.5",
          "host": ["{{baseUrl}}"],
          "path": ["alcohol", "filter"],
          "query": [
            {
              "key": "type_alcohol",
              "value": "Vodka",
              "description": "Тип напою"
            },
            {
              "key": "countries",
              "value": "Ukraine",
              "description": "Країна"
            },
            {
              "key": "volume",
              "value": "0.5",
              "description": "Об'єм, л (Nemiroff De Luxe у seed)"
            },
            {
              "key": "brand",
              "value": "Nemiroff",
              "description": "Пошук за брендом (опційно)",
              "disabled": true
            },
            {
              "key": "durability",
              "value": "40",
              "description": "Міцність % (опційно)",
              "disabled": true
            }
          ]
        },
        "description": "Фільтрація каталогу. Auth не потрібна.\nБізнес-вимоги: BR-01, BR-02, BR-04."
      },
      "response": []
    },
    {
      "name": "(Допоміжно) POST /users — Реєстрація",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Тест\",\n  \"last_name\": \"Користувач\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": ["{{baseUrl}}"],
          "path": ["users"]
        },
        "description": "Створення користувача перед login (якщо ще немає в БД)."
      },
      "response": []
    }
  ]
}
